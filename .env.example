# =========================================================================
# Education LMS - Environment variables
# Copy to .env.local and fill in the values. .env.local is .gitignored.
# =========================================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Database ---
# Local Postgres example:
#   DATABASE_URL=postgresql://user:password@localhost:5432/education_lms?schema=public
# Neon (recommended for dev — free tier):
#   1. Create a project at https://neon.tech
#   2. Copy the "Pooled connection" string into DATABASE_URL
#   3. Copy the "Direct connection" string into DIRECT_DATABASE_URL (Prisma uses it for migrations)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- JWT secrets ---
# Generate strong random secrets (≥64 bytes recommended):
#   PowerShell : [Convert]::ToBase64String((1..64 | %{ Get-Random -Max 256 }))
#   Linux/macOS: openssl rand -base64 64
JWT_ACCESS_SECRET=replace_with_a_strong_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_string

# TTLs (formats: 15m, 1h, 7d)
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# --- Bootstrap admin (created by `pnpm prisma:seed` if not present) ---
SEED_ADMIN_EMAIL=admin@education-lms.local
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_ADMIN_NAME=Platform Admin

# --- Object storage (used from Capa 3 onwards — leave empty for now) ---
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_PUBLIC_URL=

# --- LiveKit (used from Capa 7 onwards — leave empty for now) ---
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# --- SMTP (used from Capa 9 onwards — leave empty for now) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Education LMS <no-reply@education-lms.local>"
