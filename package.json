{
  "name": "education-lms",
  "version": "0.1.0",
  "private": true,
  "description": "LMS platform (Canvas-style) — Next.js 14 fullstack + Prisma + PostgreSQL",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "tsx --env-file=.env server.ts",
    "build": "prisma generate && next build",
    "start": "cross-env NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:format": "prisma format"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.668.0",
    "@aws-sdk/s3-request-presigner": "3.668.0",
    "@livekit/components-react": "2.6.2",
    "@livekit/components-styles": "1.1.4",
    "@neondatabase/serverless": "^0.9.5",
    "@prisma/adapter-neon": "5.20.0",
    "@prisma/client": "5.20.0",
    "@tanstack/react-query": "5.59.0",
    "argon2": "0.41.1",
    "clsx": "2.1.1",
    "jose": "5.9.3",
    "livekit-client": "2.5.6",
    "livekit-server-sdk": "2.7.2",
    "nanoid": "5.0.7",
    "next": "14.2.13",
    "pino": "9.4.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "resend": "4.0.0",
    "socket.io": "4.8.0",
    "socket.io-client": "4.8.0",
    "tailwind-merge": "2.5.2",
    "web-push": "3.6.7",
    "ws": "^8.20.1",
    "zod": "3.23.8",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/node": "20.16.10",
    "@types/react": "18.3.10",
    "@types/react-dom": "18.3.0",
    "@types/web-push": "3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "4.3.1",
    "@vitest/coverage-v8": "2.1.1",
    "autoprefixer": "10.4.20",
    "cross-env": "7.0.3",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.13",
    "pg": "^8.21.0",
    "postcss": "8.4.47",
    "prisma": "5.20.0",
    "tailwindcss": "3.4.13",
    "tsx": "4.19.1",
    "typescript": "5.5.4",
    "vitest": "2.1.1"
  }
}
